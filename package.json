    "alert:run": "tsx src/index.ts"
  },
  "dependencies": {
    "playwright": "^1.53.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
